{
  "project": {
    "name": "WarungPintar Lite v2.0",
    "version": "2.0",
    "description": "Aplikasi manajemen inventaris & kasbon digital untuk UMKM Indonesia",
    "type": "Mobile App",
    "platform": "Android (Flutter)",
    "backend": "Supabase (PostgreSQL + Realtime)",
    "ai_model": "Google Gemini",
    "device_target": "Vivo Y17 (Helio P35, RAM 4GB)",
    "connectivity": "4G/3G (unstable network support)",
    "release_date": "Q3 2025"
  },
  "users": {
    "primary": {
      "name": "Ibu Sari - Pemilik Warung",
      "age": 38,
      "pain_points": [
        "Stok barang sering salah hitung",
        "Kasbon tidak tertagih dengan teratur",
        "Tidak tahu barang mana yang paling laris",
        "Data hanya di satu HP"
      ]
    },
    "secondary": {
      "name": "Dewi - Pegawai Kasir",
      "age": 22,
      "pain_points": [
        "Proses pencatatan kasbon lambat",
        "Tidak bisa akses laporan keuangan"
      ]
    }
  },
  "features": {
    "inventory": {
      "description": "Manajemen stok barang real-time dengan sinkronisasi multi-perangkat",
      "functions": [
        {
          "name": "CRUD Produk",
          "fields": ["name", "category", "barcode", "cost_price", "selling_price", "stock", "min_stock", "unit", "image_url"]
        },
        {
          "name": "Manajemen Stok",
          "description": "Update stok atomik, riwayat mutasi, validasi tidak boleh negatif"
        },
        {
          "name": "Pencarian & Filter",
          "filters": ["kategori", "status stok", "rentang harga", "margin profit"]
        },
        {
          "name": "Foto Produk",
          "max_size_mb": 2,
          "storage": "Supabase Storage"
        }
      ],
      "key_requirement": "Stok di-update secara atomik; jika kasbon/penjualan gagal, stok tidak berkurang"
    },
    "kasbon": {
      "description": "Buku kasbon digital dengan tracking pembayaran bertahap",
      "functions": [
        {
          "name": "Manajemen Pelanggan",
          "fields": ["name", "phone", "address", "total_debt", "max_credit", "credit_label"]
        },
        {
          "name": "Transaksi Kasbon",
          "steps": [
            "Pilih pelanggan atau tambah baru",
            "Validasi batas kredit vs total utang aktif",
            "Tambah item produk (qty)",
            "Validasi stok ke Supabase",
            "Konfirmasi → stok berkurang, kasbon tercatat",
            "Share via WhatsApp (opsional)"
          ]
        },
        {
          "name": "Manajemen Pembayaran",
          "features": [
            "Catat cicilan parsial",
            "Ubah status: Belum Lunas → Cicilan → Lunas",
            "Riwayat pembayaran lengkap",
            "Pengingat otomatis untuk kasbon lama"
          ]
        }
      ],
      "key_requirement": "Validasi stok REAL-TIME sebelum approve kasbon; tidak boleh oversell"
    },
    "dashboard": {
      "description": "Ringkasan kondisi toko dalam satu layar",
      "widgets": [
        "Total penjualan hari ini (Rp)",
        "Total transaksi kasbon aktif",
        "Produk stok kritis (≤ min_stock)",
        "Grafik batang penjualan 7 hari",
        "Top 5 produk terlaris minggu ini"
      ],
      "refresh_interval_seconds": 10,
      "chart_library": "fl_chart"
    },
    "reports": {
      "description": "Laporan penjualan, kasbon, dan profit",
      "types": [
        {
          "name": "Laporan Penjualan",
          "periods": ["harian", "mingguan", "bulanan"],
          "metrics": ["total_revenue", "total_profit", "item_breakdown", "period_comparison"]
        },
        {
          "name": "Laporan Kasbon",
          "metrics": ["total_piutang_aktif", "customer_ranking", "jatuh_tempo_analysis", "pembayaran_received"]
        }
      ],
      "export_formats": ["CSV", "PDF"],
      "backup_strategy": "Auto backup 24 jam sekali via Supabase Storage"
    },
    "ai_analytics": {
      "description": "Server-side AI untuk prediksi & rekomendasi (bukan local processing)",
      "features": [
        {
          "name": "Prediksi Restock",
          "description": "AI analisis laju penjualan 30 hari terakhir, prediksi kapan habis",
          "output": "Top 5 produk perlu beli + estimasi qty",
          "frequency": "Senin pagi setiap minggu"
        },
        {
          "name": "Laporan Tren Teks",
          "description": "AI generate summary Bahasa Indonesia tentang penjualan & profit",
          "frequency": "Akhir bulan",
          "example": "Indomie Goreng terlaris (340 unit). Margin tertinggi dari Minuman (25%). Perhatian: Gula Pasir sering habis."
        }
      ],
      "implementation": "Google Gemini API via Supabase Edge Functions (Deno)",
      "rate_limit": "Jika API error, fitur lewat tanpa blocking operasional utama"
    }
  },
  "database": {
    "engine": "PostgreSQL",
    "host": "Supabase",
    "realtime": "Supabase Realtime (WebSocket via Postgres Changes)",
    "tables": [
      {
        "name": "stores",
        "purpose": "Data toko pemilik",
        "columns": [
          {"name": "id", "type": "UUID", "pk": true},
          {"name": "owner_id", "type": "UUID", "fk": "auth.users"},
          {"name": "name", "type": "TEXT"},
          {"name": "address", "type": "TEXT"},
          {"name": "phone", "type": "TEXT"},
          {"name": "max_credit_default", "type": "NUMERIC", "default": 500000},
          {"name": "created_at", "type": "TIMESTAMPTZ"}
        ]
      },
      {
        "name": "products",
        "purpose": "Catalog produk toko",
        "columns": [
          {"name": "id", "type": "UUID", "pk": true},
          {"name": "store_id", "type": "UUID", "fk": "stores"},
          {"name": "name", "type": "TEXT"},
          {"name": "category", "type": "TEXT"},
          {"name": "cost_price", "type": "NUMERIC(12,2)"},
          {"name": "selling_price", "type": "NUMERIC(12,2)"},
          {"name": "stock", "type": "INTEGER", "default": 0},
          {"name": "min_stock", "type": "INTEGER", "default": 5},
          {"name": "image_url", "type": "TEXT"},
          {"name": "created_at", "type": "TIMESTAMPTZ"}
        ],
        "indexes": ["store_id", "category", "created_at"]
      },
      {
        "name": "customers",
        "purpose": "Daftar pelanggan",
        "columns": [
          {"name": "id", "type": "UUID", "pk": true},
          {"name": "store_id", "type": "UUID", "fk": "stores"},
          {"name": "name", "type": "TEXT"},
          {"name": "phone", "type": "TEXT"},
          {"name": "total_debt", "type": "NUMERIC(12,2)", "default": 0},
          {"name": "max_credit", "type": "NUMERIC(12,2)"},
          {"name": "created_at", "type": "TIMESTAMPTZ"}
        ],
        "indexes": ["store_id", "total_debt"]
      },
      {
        "name": "debts",
        "purpose": "Transaksi kasbon",
        "columns": [
          {"name": "id", "type": "UUID", "pk": true},
          {"name": "customer_id", "type": "UUID", "fk": "customers"},
          {"name": "total_amount", "type": "NUMERIC(12,2)"},
          {"name": "paid_amount", "type": "NUMERIC(12,2)", "default": 0},
          {"name": "status", "type": "TEXT", "enum": ["unpaid", "partial", "paid"]},
          {"name": "created_at", "type": "TIMESTAMPTZ"}
        ],
        "indexes": ["customer_id", "status"]
      },
      {
        "name": "debt_items",
        "purpose": "Rincian item dalam kasbon",
        "columns": [
          {"name": "id", "type": "UUID", "pk": true},
          {"name": "debt_id", "type": "UUID", "fk": "debts"},
          {"name": "product_id", "type": "UUID", "fk": "products"},
          {"name": "quantity", "type": "INTEGER"},
          {"name": "price_at_time", "type": "NUMERIC(12,2)"}
        ]
      },
      {
        "name": "debt_payments",
        "purpose": "Riwayat pembayaran kasbon",
        "columns": [
          {"name": "id", "type": "UUID", "pk": true},
          {"name": "debt_id", "type": "UUID", "fk": "debts"},
          {"name": "amount", "type": "NUMERIC(12,2)"},
          {"name": "payment_method", "type": "TEXT", "default": "cash"},
          {"name": "created_at", "type": "TIMESTAMPTZ"}
        ]
      },
      {
        "name": "sales_log",
        "purpose": "Log penjualan tunai",
        "columns": [
          {"name": "id", "type": "UUID", "pk": true},
          {"name": "product_id", "type": "UUID", "fk": "products"},
          {"name": "quantity", "type": "INTEGER"},
          {"name": "total_price", "type": "NUMERIC(12,2)"},
          {"name": "created_at", "type": "TIMESTAMPTZ"}
        ],
        "indexes": ["product_id", "created_at"]
      },
      {
        "name": "stock_mutations",
        "purpose": "Audit trail perubahan stok",
        "columns": [
          {"name": "id", "type": "UUID", "pk": true},
          {"name": "product_id", "type": "UUID", "fk": "products"},
          {"name": "change_amount", "type": "INTEGER"},
          {"name": "reason", "type": "TEXT", "enum": ["sale", "debt", "restock", "correction"]},
          {"name": "created_at", "type": "TIMESTAMPTZ"}
        ]
      }
    ]
  },
  "architecture": {
    "frontend": {
      "framework": "Flutter",
      "language": "Dart",
      "state_management": "Riverpod",
      "local_cache": "Hive",
      "http_client": "http / dio",
      "offline_strategy": "Delta sync dengan Hive cache"
    },
    "backend": {
      "platform": "Supabase",
      "database": "PostgreSQL",
      "auth": "Supabase Auth (JWT)",
      "realtime": "Postgres Changes (WebSocket)",
      "edge_functions": "Deno (untuk Gemini API calls)",
      "storage": "Supabase Storage (foto produk, backup CSV)"
    },
    "ai": {
      "provider": "Google Gemini API",
      "deployment": "Via Supabase Edge Functions (server-side)",
      "models": ["Gemini Pro"],
      "use_cases": ["Prediksi restock", "Laporan tren"],
      "client_side_processing": false
    },
    "push_notifications": {
      "provider": "Firebase Cloud Messaging (FCM)",
      "triggers": ["Stok kritis", "Kasbon jatuh tempo"]
    }
  },
  "performance_targets": {
    "cold_start": "< 3 detik",
    "warm_start": "< 1 detik",
    "sync_latency": "< 500ms",
    "product_list_load": "< 800ms (200 item, 20/page)",
    "search_response": "< 300ms (debounce 300ms)",
    "apk_size": "< 30MB",
    "ram_idle": "< 120MB",
    "ram_active": "< 200MB",
    "battery_consumption_per_hour": "< 5%",
    "data_transfer_per_session": "< 500KB"
  },
  "constraints": {
    "offline_first": true,
    "low_end_device": true,
    "unstable_network": true,
    "security_critical_financial": true,
    "multi_device_sync": true,
    "no_local_ai_processing": true
  },
  "security": {
    "auth": "Supabase Auth (Email & Password)",
    "token_expiry": "1 jam (access), 7 hari (refresh)",
    "encryption": "TLS 1.3",
    "certificate_pinning": true,
    "rls_policies": "Row-level security on all tables",
    "rbac": ["Admin", "Cashier"],
    "audit_logging": "90 hari minimum",
    "data_deletion": "Soft delete + permanent after 30 hari"
  },
  "timeline": {
    "phase_1": {
      "name": "Foundation",
      "duration_days": 2,
      "tasks": [
        "Setup Supabase",
        "Design & migrate database",
        "RLS policies",
        "Auth system"
      ]
    },
    "phase_2": {
      "name": "Core Features",
      "duration_days": 3,
      "tasks": [
        "Inventory CRUD",
        "Kasbon management",
        "Dashboard"
      ]
    },
    "phase_3": {
      "name": "Advanced",
      "duration_days": 2,
      "tasks": [
        "Offline-first implementation",
        "Reports & export",
        "AI integration"
      ]
    },
    "phase_4": {
      "name": "Testing & Polish",
      "duration_days": 3,
      "tasks": [
        "Unit tests",
        "Integration tests",
        "Performance tuning",
        "Security audit"
      ]
    }
  },
  "success_metrics": {
    "technical": {
      "uptime": ">= 99.5%",
      "error_rate": "< 0.5%",
      "crash_rate": "< 1%"
    },
    "product": {
      "d30_retention": ">= 60%",
      "dau_mau_ratio": ">= 40%",
      "app_rating": ">= 4.3 stars",
      "onboarding_time": "< 10 menit",
      "nps": ">= 50"
    }
  },
  "dependencies": {
    "external_apis": [
      "Google Gemini API (AI predictions)",
      "Firebase Cloud Messaging (Push notifications)",
      "Supabase REST API"
    ],
    "libraries": [
      "flutter/material",
      "riverpod",
      "hive",
      "supabase",
      "fl_chart",
      "firebase_messaging"
    ]
  }
}